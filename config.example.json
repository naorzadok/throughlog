{
  "llm": {
    "provider": "openrouter",
    "base_url": "https://openrouter.ai/api/v1",
    "model": "nvidia/nemotron-3-super-120b-a12b:free",
    "model_fallback": "qwen/qwen3-next-80b-a3b-instruct:free",
    "reasoning_effort": "",
    "api_key_env": "OPENROUTER_API_KEY",
    "api_key": "",
    "timeout_sec": 600,
    "max_retries": 3,
    "max_requests_per_min": 18,
    "circuit_breaker": false,
    "local_endpoint": "http://localhost:11434",
    "local_model": "llama3.1:8b"
  },
  "privacy": {
    "allowlist_extra": [],
    "capture_diffs": false,
    "diff_max_lines": 400,
    "diff_max_bytes": 65536,
    "ignore_globs": [],
    "clipboard_preview": false,
    "clipboard_preview_chars": 256
  },
  "synthesis": {
    "write_entries": true,
    "entry_max_tokens": 1500,
    "entry_period": "month",
    "summary_cadence": "weekly",
    "entry_batch": "adaptive",
    "max_input_tokens": "auto",
    "max_batch_days": 7
  },
  "init": {
    "llm_enrich": false
  },
  "paths": {
    "data_dir": "data",
    "journal_dir": "journal"
  },
  "schedule": {
    "synthesize_at": ""
  },
  "report": {
    "slack_webhook": "",
    "github_token": ""
  },
  "integrations": {
    "github": {
      "token": ""
    }
  },
  "relay": {
    "tokens": {
      "CHANGE-ME-secret-token": "my-account"
    }
  },
  "sync": {
    "endpoint": "",
    "token": ""
  }
}
